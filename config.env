# -- Azure Files Mount Configuration -----------------------------------------
# Edit these values to match your environment.

# Instance type: "AML" or "AFH" (AI Foundry Hub)
INSTANCE_TYPE="AML"

# Storage account name
STORAGE_ACCOUNT=""

# File share name (used when INSTANCE_TYPE="AML")
SHARE_NAME=""

# File share names for AI Foundry (used when INSTANCE_TYPE="AFH")
# Space-separated list of share names in the format: workspaceId-code
# Example: SHARE_NAMES="xxxx-code xxxxx-code"
SHARE_NAMES=""

# Conda environment
CONDA_ENV="azureml_py310_sdkv2"

# Token refresh interval in seconds (24 hours = 86400)
REFRESH_INTERVAL=86400

# Mount options
MOUNT_UID=1000
DIR_MODE=0755
FILE_MODE=0755

# -- Internal paths (change only if needed) ----------------------------------
PID_FILE="/var/run/token_refresh.pid"
REFRESH_LOG="/var/log/token_refresh.log"
INSTALL_DIR="/opt/azfiles"
SERVICE_NAME="azfiles-mount"
INSTALL_MARKER="/var/log/azfiles_install_done"